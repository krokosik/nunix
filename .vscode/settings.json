{
  "nix.enableLanguageServer": true,
  "nix.serverPath": ["nixd"], // or "nixd", or ["executable", "argument1", ...]
  // LSP config can be passed via the ``nix.serverSettings.{lsp}`` as shown below.
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "nixfmt"
        ],
      }
    }
  }
}
  # --- START CODER VSCODE coder.qodl.eu ---
Host coder-vscode.coder.qodl.eu--*
  ConnectTimeout 0
  ForwardAgent yes
  ForwardX11 yes
  ForwardX11Trusted yes
  LogLevel ERROR
  ProxyCommand /home/krokosik/.config/Code/User/globalStorage/coder.coder-remote/coder.qodl.eu/bin/coder-linux-amd64 --global-config /home/krokosik/.config/Code/User/globalStorage/coder.coder-remote/coder.qodl.eu ssh --stdio --usage-app vscode --disable-autostart --network-info-dir /home/krokosik/.config/Code/User/globalStorage/coder.coder-remote/net --ssh-host-prefix coder-vscode.coder.qodl.eu-- %h
  SetEnv  CODER_SSH_SESSION_TYPE=vscode
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  # --- END CODER VSCODE coder.qodl.eu ---


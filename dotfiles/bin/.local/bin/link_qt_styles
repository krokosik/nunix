#!/usr/bin/env python
import contextlib
import os
from pathlib import Path
import argparse

parser = argparse.ArgumentParser("Link Qt styles directories from system to environment")
parser.add_argument("--revert", action="store_true", help="Revert symlinks instead of creating them")
args = parser.parse_args()

qt5_env_paths = []
qt6_env_paths = []

with contextlib.suppress(ImportError):
    from PyQt5.QtCore import QLibraryInfo
    qt5_env_paths.append(QLibraryInfo.location(QLibraryInfo.LibraryLocation.PluginsPath))

with contextlib.suppress(ImportError):
    from PySide2.QtCore import QLibraryInfo
    qt5_env_paths.append(QLibraryInfo.location(QLibraryInfo.LibraryLocation.PluginsPath))

with contextlib.suppress(ImportError):
    from PyQt6.QtCore import QLibraryInfo
    qt6_env_paths.append(QLibraryInfo.path(QLibraryInfo.LibraryPath.PluginsPath))

with contextlib.suppress(ImportError):
    from PySide6.QtCore import QLibraryInfo
    qt6_env_paths.append(QLibraryInfo.path(QLibraryInfo.LibraryPath.PluginsPath))

qt5_system_path = "/usr/lib/qt/plugins"
qt6_system_path = "/usr/lib/qt6/plugins"

for system_path, env_paths in [(qt5_system_path, qt5_env_paths), (qt6_system_path, qt6_env_paths)]:
    system_path = Path(system_path) / "styles"
    for env_path in env_paths:
        env_path = Path(env_path) / "styles"
        if system_path.exists() and system_path != env_path:
            if env_path.exists() and env_path.is_symlink():
                env_path.unlink()
                
            if args.revert:
                print(f"Reverted symlink {env_path}")
            else:
                print(f"Symlinking {env_path} ---> {system_path}")
                os.symlink(system_path, env_path, target_is_directory=True)

#!/bin/bash

set -euo pipefail

STATE_DIR="$HOME/.local/state/hypr"
STATE_FILE="$STATE_DIR/idle-lock.mode"
ACTIVE_CONF="$HOME/.config/hypr/hypridle.conf"
LOCK_AND_SCREENOFF_CONF="$HOME/.config/hypr/hypridle.lock+screenoff.conf"
SCREENOFF_ONLY_CONF="$HOME/.config/hypr/hypridle.screenoff-only.conf"

mkdir -p "$STATE_DIR"

detect_mode_from_active_conf() {
  if [[ -f "$ACTIVE_CONF" ]] && grep -Eq '^[[:space:]]*on-timeout[[:space:]]*=[[:space:]]*loginctl lock-session([[:space:]]|$)' "$ACTIVE_CONF"; then
    printf '%s\n' "lock+screenoff"
  else
    printf '%s\n' "screenoff-only"
  fi
}

detect_current_mode() {
  if ! pgrep -x hypridle >/dev/null; then
    printf '%s\n' "disabled"
    return
  fi

  detect_mode_from_active_conf
}

if [[ -f "$STATE_FILE" ]]; then
  current_mode=$(<"$STATE_FILE")
else
  current_mode=$(detect_current_mode)
fi

if [[ $current_mode != "lock+screenoff" && $current_mode != "screenoff-only" && $current_mode != "disabled" ]]; then
  current_mode=$(detect_current_mode)
fi

printf '%s\n' "$current_mode" >"$STATE_FILE"

if [[ $current_mode == "lock+screenoff" ]]; then
  next_mode="screenoff-only"
  cp "$SCREENOFF_ONLY_CONF" "$ACTIVE_CONF"
  notify-send "󱫖    Idle mode: screen off only"
  pkill -x hypridle || true
  uwsm-app -- hypridle >/dev/null 2>&1 &
elif [[ $current_mode == "screenoff-only" ]]; then
  next_mode="disabled"
  notify-send "󱫖    Idle mode: disabled"
  pkill -x hypridle || true
else
  next_mode="lock+screenoff"
  cp "$LOCK_AND_SCREENOFF_CONF" "$ACTIVE_CONF"
  notify-send "󱫖    Idle mode: lock + screen off"
  pkill -x hypridle || true
  uwsm-app -- hypridle >/dev/null 2>&1 &
fi

printf '%s\n' "$next_mode" >"$STATE_FILE"

pkill -RTMIN+9 waybar || true
